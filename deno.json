{
  "compilerOptions": {
    "lib": ["deno.window", "dom", "dom.iterable", "esnext"],
    "strict": true
  },
  "fmt": {
    "lineWidth": 100,
    "semiColons": true
  },
  "imports": {
    "zod": "npm:zod@4.4.3"
  },
  "lock": false,
  "minimumDependencyAge": 0,
  "nodeModulesDir": "none",
  "tasks": {
    "check:functions": "deno check supabase/functions/create-pairing-code/index.ts supabase/functions/pair-device/index.ts supabase/functions/ingest-events/index.ts",
    "test:functions": "deno test --allow-env supabase/functions/tests"
  }
}
